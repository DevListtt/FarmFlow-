# FarmFlow Configuration
# ERP Agricole Open Source

# ===========================================
# ENVIRONNEMENT
# ===========================================
ENVIRONMENT=development
DEBUG=True

# ===========================================
# BASE DE DONNÉES POSTGRESQL
# ===========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=farmflow
POSTGRES_PASSWORD=farmflow
POSTGRES_DB=farmflow

# ===========================================
# INFLUXDB (Time-series pour IoT)
# ===========================================
INFLUXDB_HOST=localhost
INFLUXDB_PORT=8086
INFLUXDB_USER=farmflow
INFLUXDB_PASSWORD=farmflow
INFLUXDB_DB=farmflow_metrics

# ===========================================
# REDIS (Cache et sessions)
# ===========================================
REDIS_URL=redis://localhost:6379/0

# ===========================================
# JWT (Authentification)
# ===========================================
SECRET_KEY=farmflow-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================================
# MQTT (IoT)
# ===========================================
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=

# ===========================================
# COMMUNICATION
# ===========================================
# Twilio (SMS/VoIP)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid (Email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@farmflow.com

# WhatsApp
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# ===========================================
# API EXTERNES
# ===========================================
# Météo
WEATHER_API_KEY=

# Zapier
ZAPIER_WEBHOOK_URL=

# Banque / synchronisation bancaire
BANK_SYNC_PROVIDER=
BANK_SYNC_CLIENT_ID=
BANK_SYNC_CLIENT_SECRET=
BANK_ALERT_MIN_BALANCE=0

# IA / assistant contextualisé
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# ===========================================
# STOCKAGE DE FICHIERS
# ===========================================
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE=104857600  # 100MB

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=["*"]
